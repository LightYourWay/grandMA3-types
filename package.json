{
	"name": "grandma3-types",
	"version": "0.8.1",
	"description": "TypeScript definitions for grandMA3 Lua library.",
	"types": "index.d.ts",
	"scripts": {
		"lint:check": "prettier --check \"typings/**/*.ts\"",
		"lint:fix": "prettier --write \"typings/**/*.ts\"",
		"tsc": "tsc --watch",
		"tsc:check": "tsc --noEmit"
	},
	"files": [
		"index.d.ts",
		"typings/"
	],
	"prettier": {
		"printWidth": 100,
		"proseWrap": "never",
		"singleQuote": true,
		"trailingComma": "all",
		"useTabs": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LightYourWay/grandMA3-types.git"
	},
	"author": "Lukas Runge",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/LightYourWay/grandMA3-types/issues"
	},
	"homepage": "https://github.com/LightYourWay/grandMA3-types#readme",
	"devDependencies": {
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"lua-types": "^2.14.1",
		"prettier": "^3.8.3",
		"typescript": "6.0.2",
		"typescript-to-lua": "1.36.0"
	},
	"keywords": [
		"grandma3",
		"ma",
		"lighting",
		"typescript",
		"types",
		"typings"
	]
}
